<!DOCTYPE html>
<html lang="{{ store.locale }}" dir="{{ store.locale == 'ar' ? 'rtl' : 'ltr' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ page.meta_description }}">
    <meta name="keywords" content="{{ page.meta_keywords }}">
    <meta property="og:title" content="{{ page.title }}">
    <meta property="og:description" content="{{ page.meta_description }}">
    <meta property="og:image" content="{{ store.logo }}">
    <meta property="og:url" content="{{ request.url }}">
    <title>{{ page.title }} | {{ store.name }}</title>

    {# Salla Twilight Head - 횠짭횢혚횢혡횠쨔 횠쨀횢혘횠짹횢혡횠짢횠짧횠짠횠짧 횢혞횢혚횢혙횢혖횠짠횠짧 Twilight 횠짠횢혙횠짙횠쨀횠짠횠쨀횢혡횠짤 #}
    {{ twilight.head() }}

    {# Google Fonts - 횠짰횠쨌 Tajawal 횠짠횢혙횠짠횠짯횠짧횠짹횠짠횢혖횢혡 횢혙횢혙횠쨔횠짹횠짢횢혡횠짤 #}
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">

    {# Font Awesome Icons - 횠짙횢혡횢혗횢혞횢혛횠짠횠짧 횠짠횠짯횠짧횠짹횠짠횢혖횢혡횠짤 #}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-QDAkCKwIuBRESQd1i2BzHbMIVc6ktlW+V6mask5c4D798JXc8jof8kqobQyTXn0dXjP83I08QT60JFDTRcnotw==" crossorigin="anonymous" referrerpolicy="no-referrer">

    {# Theme CSS - 횢혚횢혙횢혖 횠짠횢혙횠짧횢혛횠쨀횢혡횢혗횠짠횠짧 횠짠횢혙횠짹횠짝횢혡횠쨀횢혡 #}
    <link rel="stylesheet" href="{{ 'assets/css/app.css' | asset }}">

    {# Customizable CSS Variables - 횢혚횠짧횠쨘횢혡횠짹횠짠횠짧 횠짠횢혙횠짧횠짰횠쨉횢혡횠쨉 횢혙횢혙횠쨔횢혚횢혡횢혙 #}
    <style>
        :root {
            {# 횠짠횢혙횠짙횢혙횢혞횠짠횢혛 횠짠횢혙횠짙횠쨀횠짠횠쨀횢혡횠짤 횢혙횢혙횠짬횢혡횢혚 - 횢혡횢혚횢혘횢혛 횠짧횠짰횠쨉횢혡횠쨉횢혝횠짠 횢혚횢혛 횢혙횢혞횠짯횠짤 횠짠횢혙횠짜횠짱횠짠횠짹횠짤 #}
            --primary-color: {{ theme.settings.primary_color | default('#C9A84C') }};
            --primary-light: {{ theme.settings.primary_light | default('#E8D48B') }};
            --primary-dark: {{ theme.settings.primary_dark | default('#8B7C3E') }};

            {# 횠짙횢혙횢혞횠짠횢혛 횠짠횢혙횠짰횢혙횢혖횢혡횠짤 횢혞횠짠횢혙횠짢횠쨌횠짠횢혗횠짠횠짧 #}
            --bg-color: {{ theme.settings.bg_color | default('#0A0A0F') }};
            --card-color: {{ theme.settings.card_color | default('#12121A') }};
            --card-hover: {{ theme.settings.card_hover | default('#1A1A25') }};
            --border-color: {{ theme.settings.border_color | default('#1E1E2A') }};

            {# 횠짙횢혙횢혞횠짠횢혛 횠짠횢혙횢혛횠쨉횢혞횠쨉 #}
            --text-primary: #FFFFFF;
            --text-secondary: #9CA3AF;
            --text-muted: #6B7280;

            {# 횠짠횢혙횠짰횠쨌횢혞횠쨌 횢혞횠짠횢혙횢혚횠쨀횠짠횢혖횠짠횠짧 #}
            --font-family: 'Tajawal', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            --radius-sm: 8px;
            --radius-md: 12px;
            --radius-lg: 20px;
            --radius-xl: 24px;
            --transition-speed: 0.3s;
        }

        {# 횠짠횢혙횢혞횠쨋횠쨔 횠짠횢혙횢혙횢혡횢혙횢혡 횠짠횢혙횠짠횢혖횠짧횠짹횠짠횠쨋횢혡 횢혙횢혙횠짬횢혡횢혚 #}
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            background-color: var(--bg-color);
            color: var(--text-primary);
            font-family: var(--font-family);
            line-height: 1.6;
            scroll-behavior: smooth;
        }
    </style>
</head>
<body class="velora-body">
    {# 횠짧횠짰횠쨌횢혡 횠짜횢혙횢혟 횠짠횢혙횢혚횠짯횠짧횢혞횢혟 횠짠횢혙횠짹횠짝횢혡횠쨀횢혡 - 횢혚횢혝횢혚 횢혙횢혙횢혞횠쨉횢혞횢혙횢혡횠짤 #}
    <a href="#main-content" class="skip-link">{{ trans('accessibility.skip_to_content', '횠짠횠째횢혝횠짢 횠짜횢혙횢혟 횠짠횢혙횢혚횠짯횠짧횢혞횢혟 횠짠횢혙횠짹횠짝횢혡횠쨀횢혡') }}</a>

    {# 횢혚횢혘횢혞횢혛 횠짠횢혙횠짹횠짙횠쨀 - 횢혡횠짯횠짧횢혞횢혡 횠쨔횢혙횢혟 횠짠횢혙횢혗횠짠횠짝횢혚횠짤 횠짠횢혙횠쨔횢혙횢혞횢혡횠짤 횢혞횠짠횢혙횠쨈횠쨔횠짠횠짹 횢혞횠짠횢혙횢혗횠짠횠짝횢혚횠짤 횠짠횢혙횠짹횠짝횢혡횠쨀횢혡횠짤 #}
    {% include 'components/header.twig' %}

    {# 횢혗횠짠횠짝횢혚횠짤 횠짠횢혙횢혝횠짠횠짧횢혖 횠짠횢혙횢혚횠짯횢혚횢혞횢혙 - 횠짧횠쨍횢혝횠짹 횠쨔횢혛횠짱 횠짠횢혙횠쨋횠쨘횠쨌 횠쨔횢혙횢혟 횠짠횢혙횢혝횠짠횢혚횠짢횠짹횠짭횠짹 #}
    {% include 'partials/mobile-menu.twig' %}

    {# 횢혛횠짠횢혖횠째횠짤 횠짠횢혙횠짢횠짯횠짬 - 횠짧횠쨍횢혝횠짹 횠쨔횢혛횠짱 횠짠횢혙횠쨋횠쨘횠쨌 횠쨔횢혙횢혟 횠짙횢혡횢혗횢혞횢혛횠짤 횠짠횢혙횠짢횠짯횠짬 #}
    {% include 'partials/search-overlay.twig' %}

    {# 횠짠횢혙횢혚횠짯횠짧횢혞횢혟 횠짠횢혙횠짹횠짝횢혡횠쨀횢혡 - 횢혡횠짧횠쨘횢혡횠짹 횠짯횠쨀횠짢 횠짠횢혙횠쨉횢혖횠짯횠짤 #}
    <main id="main-content" role="main">
        {% block content %}{% endblock %}
    </main>

    {# 횢혚횢혘횢혞횢혛 횠짠횢혙횠짧횠째횢혡횢혡횢혙 - 횢혡횠짯횠짧횢혞횢혡 횠쨔횢혙횢혟 횠짠횢혙횠짹횢혞횠짠횠짢횠쨌 횢혞횠짠횢혙횠짠횠쨈횠짧횠짹횠짠횢혘 횢혞횠짠횢혙횠짧횢혞횠짠횠쨉횢혙 #}
    {% include 'components/footer.twig' %}

    {# 횠짼횠짹 횠짠횢혙횠쨔횢혞횠짱횠짤 횠짜횢혙횢혟 횠짠횢혙횠짙횠쨔횢혙횢혟 - 횢혡횠쨍횢혝횠짹 횠쨔횢혛횠짱 횠짠횢혙횠짧횢혚횠짹횢혡횠짹 횢혙횢혙횠짙횠쨀횢혖횢혙 #}
    <button id="back-to-top" class="back-to-top" aria-label="{{ trans('accessibility.back_to_top', '횠짠횢혙횠쨔횢혞횠짱횠짤 횠짜횢혙횢혟 횠짠횢혙횠짙횠쨔횢혙횢혟') }}">
        <i class="fas fa-chevron-up"></i>
    </button>

    {# 횠쨀횢혘횠짹횢혡횠짢횠짧횠짠횠짧 Twilight 횠짠횢혙횠쨋횠짹횢혞횠짹횢혡횠짤 - 횢혡횠짭횠짢 횠짙횢혛 횠짧횢혘횢혞횢혛 횢혖횢혡 횠짠횢혙횢혛횢혝횠짠횢혡횠짤 #}
    {{ twilight.footer() }}

    {# JavaScript 횠짠횢혙횠짬횢혡횢혚 - 횢혡횠짯횠짧횢혞횢혡 횠쨔횢혙횢혟 횠짠횢혙횠짧횢혖횠짠횠쨔횢혙횠짠횠짧 횢혞횠짠횢혙횢혚횢혡횠짼횠짠횠짧 #}
    <script src="{{ 'assets/js/app.js' | asset }}"></script>

    {# 횢혛횠쨉 횢혚횠짰횢혖횢혡 횢혙횢혙횢혚횠짧횠쨘횢혡횠짹횠짠횠짧 횠짠횢혙횠쨔횠짠횢혚횠짤 횠짠횢혙횢혚횠쨀횠짧횠짰횠짱횢혚횠짤 횢혖횢혡 JS #}
    <script>
        window.themeConfig = {
            locale: '{{ store.locale }}',
            isRTL: {{ store.locale == 'ar' ? 'true' : 'false' }},
            storeName: '{{ store.name }}',
            cartCount: {{ cart.count | default(0) }}
        };
    </script>
</body>
</html>
