{#
  횢혗횠짠횠짝횢혚횠짤 횠짠횢혙횠짭횢혞횠짠횢혙 - Mobile Menu Partial
  횢혡횠짧횢혚 횠쨔횠짹횠쨋횢혝횠짠 횠쨔횢혙횢혟 횠짠횢혙횠짙횠짭횢혝횠짼횠짤 횠짠횢혙횠쨉횠쨘횢혡횠짹횠짤 횠쨔횢혛횠짱 횠짠횢혙횠쨋횠쨘횠쨌 횠쨔횢혙횢혟 횠짼횠짹 횠짠횢혙횢혗횠짠횠짝횢혚횠짤
#}

<div class="mobile-menu-overlay"></div>

<nav class="mobile-menu">
    {# 횠짹횠짙횠쨀 횠짠횢혙횢혗횠짠횠짝횢혚횠짤 - Menu Header #}
    <div class="mobile-menu-header">
        <h2 class="mobile-menu-title">{{ store.name }}</h2>
        <button class="mobile-menu-close" aria-label="횠짜횠쨘횢혙횠짠횢혗 횠짠횢혙횢혗횠짠횠짝횢혚횠짤">
            창혵혮
        </button>
    </div>
    
    {# 횠짹횢혞횠짠횠짢횠쨌 횠짠횢혙횠짧횢혛횢혗횢혙 - Navigation Links #}
    <ul class="mobile-menu-nav">
        <li>
            <a href="/" class="mobile-menu-link">횠짠횢혙횠짹횠짝횢혡횠쨀횢혡횠짤</a>
        </li>
        <li>
            <a href="/products" class="mobile-menu-link">횠짠횢혙횢혚횢혛횠짧횠짭횠짠횠짧</a>
        </li>
        <li>
            <a href="/blog" class="mobile-menu-link">횠짠횢혙횢혚횠짱횢혞횢혛횠짤</a>
        </li>
        <li>
            <a href="/about" class="mobile-menu-link">횠쨔횢혛 횠짠횢혙횢혚횠짧횠짭횠짹</a>
        </li>
        <li>
            <a href="/contact" class="mobile-menu-link">횠짠횠짧횠쨉횢혙 횠짢횢혛횠짠</a>
        </li>
    </ul>
    
    {# 횠짠횢혙횢혖횠짝횠짠횠짧 - Categories #}
    {% if categories %}
        <div class="mobile-menu-categories">
            <h3 style="margin-bottom: 1rem;">횠짠횢혙횢혖횠짝횠짠횠짧</h3>
            <ul class="mobile-menu-nav">
                {% for category in categories %}
                    <li>
                        <a href="/products?category={{ category.id }}" class="mobile-menu-link">
                            {{ category.name }}
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}
    
    {# 횠짙횠짼횠짹횠짠횠짹 횠짠횢혙횢혚횠쨀횠짧횠짰횠짱횢혚 - User Actions #}
    <div class="mobile-menu-footer">
        {% if user %}
            <div style="margin-bottom: 1rem;">
                <p style="color: var(--text-secondary); margin-bottom: 0.5rem;">횢혚횠짹횠짯횠짢횠짠횢혢횠혣 {{ user.name }}</p>
                <a href="/account" class="btn btn-secondary" style="width: 100%; margin-bottom: 0.5rem;">
                    횠짯횠쨀횠짠횠짢횢혡
                </a>
                <form method="post" action="/logout" style="margin: 0;">
                    <button type="submit" class="btn btn-outline" style="width: 100%;">
                        횠짧횠쨀횠짭횢혡횢혙 횠짠횢혙횠짰횠짹횢혞횠짭
                    </button>
                </form>
            </div>
        {% else %}
            <a href="/login" class="btn btn-primary" style="width: 100%; margin-bottom: 0.5rem; display: block;">
                횠짱횠짰횢혞횢혙
            </a>
            <a href="/register" class="btn btn-secondary" style="width: 100%; display: block;">
                횠짜횢혛횠쨈횠짠횠징 횠짯횠쨀횠짠횠짢
            </a>
        {% endif %}
        
        {# 횢혞횠쨀횠짠횠짝횢혙 횠짠횢혙횠짧횢혞횠짠횠쨉횢혙 횠짠횢혙횠짠횠짭횠짧횢혚횠짠횠쨔횢혡 - Social Media #}
        {% if store.social_media %}
            <div style="margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--dark-border);">
                <p style="font-size: 0.875rem; color: var(--text-muted); margin-bottom: 0.75rem;">횢혚횠짧횠짠횠짢횠쨔횠짤 횠짠횢혙횢혚횠짧횠짭횠짹</p>
                <div style="display: flex; gap: 0.5rem;">
                    {% if store.social_media.facebook %}
                        <a href="{{ store.social_media.facebook }}" title="횢혖횢혡횠쨀횠짢횢혞횢혘" style="flex: 1;">
                            <span style="display: block; padding: 0.75rem; background: var(--dark-card-hover); border-radius: 8px; text-align: center;">f</span>
                        </a>
                    {% endif %}
                    {% if store.social_media.twitter %}
                        <a href="{{ store.social_media.twitter }}" title="횠짧횢혞횢혡횠짧횠짹" style="flex: 1;">
                            <span style="display: block; padding: 0.75rem; background: var(--dark-card-hover); border-radius: 8px; text-align: center;">챨혶혮혧</span>
                        </a>
                    {% endif %}
                    {% if store.social_media.instagram %}
                        <a href="{{ store.social_media.instagram }}" title="횠짜횢혛횠쨀횠짧횠짠횠짭횠짹횠짠횢혚" style="flex: 1;">
                            <span style="display: block; padding: 0.75rem; background: var(--dark-card-hover); border-radius: 8px; text-align: center;">챨혺혫쨌</span>
                        </a>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    </div>
</nav>
