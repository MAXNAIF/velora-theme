{#
  횢혘횠짠횠짹횠짧 횠짠횢혙횢혚횢혛횠짧횠짭 - 횢혡횢혧횠쨀횠짧횠짰횠짱횢혚 횢혖횢혡 횠짠횢혙횠쨉횢혖횠짯횠짤 횠짠횢혙횠짹횠짝횢혡횠쨀횢혡횠짤 횢혞횠쨉횢혖횠짯횠짤 횠짠횢혙횢혚횢혛횠짧횠짭횠짠횠짧 횢혞횠짠횢혙횠짢횠짯횠짬
  Product Card Component - Used across homepage, products page, and search
  
  횠짠횢혙횢혚횠짧횠쨘횢혡횠짹횠짠횠짧 횠짠횢혙횢혚횠쨌횢혙횢혞횠짢횠짤: product
  Required Variables: product
#}

<div class="product-card" data-product-id="{{ product.id }}">
    {# 횠쨉횢혞횠짹횠짤 횠짠횢혙횢혚횢혛횠짧횠짭 - Product Image #}
    <div class="product-image-wrapper">
        <img 
            src="{{ product.image }}" 
            alt="{{ product.name }}"
            class="product-image"
            loading="lazy"
        >
        
        {# 횠쨈횠짠횠짹횠짠횠짧 - Badges #}
        {% if product.is_bestseller %}
            <span class="product-badge">횠짠횢혙횠짙횢혘횠짬횠짹 횢혚횠짢횢혡횠쨔횠짠횢혢</span>
        {% elseif product.is_new %}
            <span class="product-badge new">횠짭횠짱횢혡횠짱</span>
        {% elseif product.discount_percentage %}
            <span class="product-badge discount">{{ product.discount_percentage }}%</span>
        {% endif %}
        
        {# 횠짼횠짹 횢혗횠짠횠짝횢혚횠짤 횠짠횢혙횠짹횠쨘횠짢횠짠횠짧 - Wishlist Button #}
        <button 
            class="product-wishlist" 
            data-product-id="{{ product.id }}"
            title="횠짜횠쨋횠짠횢혖횠짤 횢혙횢혙횢혗횠짠횠짝횢혚횠짤 횠짠횢혙횢혚횢혖횠쨋횢혙횠짤"
            aria-label="횠짜횠쨋횠짠횢혖횠짤 {{ product.name }} 횢혙횢혙횢혗횠짠횠짝횢혚횠짤 횠짠횢혙횢혚횢혖횠쨋횢혙횠짤"
        >
            창혶짚챦쨍혧
        </button>
    </div>
    
    {# 횢혚횠짯횠짧횢혞횢혟 횠짠횢혙횢혚횢혛횠짧횠짭 - Product Body #}
    <div class="product-body">
        {# 횢혖횠짝횠짤 횠짠횢혙횢혚횢혛횠짧횠짭 - Category #}
        {% if product.category %}
            <p class="product-category">{{ product.category }}</p>
        {% endif %}
        
        {# 횠짠횠쨀횢혚 횠짠횢혙횢혚횢혛횠짧횠짭 - Product Name #}
        <h3 class="product-name">{{ product.name }}</h3>
        
        {# 횠짠횢혙횠짧횢혗횢혡횢혡횢혚 횢혞횠짠횢혙횢혛횠짭횢혞횢혚 - Rating #}
        <div class="product-rating">
            <div class="stars">
                {% for i in 1..5 %}
                    {% if i <= product.rating %}
                        <span class="star">창혱혚</span>
                    {% else %}
                        <span class="star empty">창혱혚</span>
                    {% endif %}
                {% endfor %}
            </div>
            <span class="rating-count">({{ product.reviews_count }})</span>
        </div>
        
        {# 횠짠횢혙횠쨀횠쨔횠짹 - Price #}
        <div class="product-price">
            {% if product.old_price %}
                <span class="price-old">{{ product.old_price | currency }}</span>
            {% endif %}
            <span>{{ product.price | currency }}</span>
        </div>
        
        {# 횠짠횢혙횠짙횠짼횠짹횠짠횠짹 - Action Buttons #}
        <div class="product-actions">
            <button 
                class="btn btn-primary btn-add-cart"
                data-product-id="{{ product.id }}"
                type="button"
                title="횠짜횠쨋횠짠횢혖횠짤 횠짜횢혙횢혟 횠짠횢혙횠쨀횢혙횠짤"
            >
                챨혺혴혪 횠짙횠쨋횢혖 횢혙횢혙횠쨀횢혙횠짤
            </button>
            <button 
                class="btn btn-outline btn-quick-view"
                data-product-id="{{ product.id }}"
                type="button"
                title="횠쨔횠짹횠쨋 횠쨀횠짹횢혡횠쨔"
            >
                챨혺혩혖챦쨍혧
            </button>
        </div>
    </div>
</div>
