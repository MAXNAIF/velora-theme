{# ملف صفحة تفاصيل المنتج - Product Detail Page #}
{% extends "layouts/master.twig" %}

{% block title %}{{ product.name }} - Velora{% endblock %}
{% block description %}{{ product.name }} - {{ product.description }}{% endblock %}

{% block content %}

{# === التنقل الهرمي Breadcrumb Navigation === #}
<div class="bg-dark-card/50 border-b border-dark-border sticky top-24 z-40">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <div class="flex items-center gap-2 text-sm">
            <a href="/" class="text-gold hover:text-gold-light transition-colors">
                <i class="fas fa-home ms-1"></i>الرئيسية
            </a>
            <i class="fas fa-chevron-left text-gray-500"></i>
            <a href="/#products" class="text-gold hover:text-gold-light transition-colors">المنتجات</a>
            <i class="fas fa-chevron-left text-gray-500"></i>
            <span class="text-gray-400">{{ product.name }}</span>
        </div>
    </div>
</div>

{# === محتوى صفحة المنتج Main Product Content === #}
<section class="py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

            {# === معرض صور المنتج Product Image Gallery === #}
            <div class="space-y-6">
                {# الصورة الرئيسية #}
                <div class="relative rounded-2xl overflow-hidden bg-dark-card border-2 border-gold/30 group h-96 sm:h-96 lg:h-[500px]">
                    <img
                        id="main-product-image"
                        src="{{ product.image.url }}"
                        alt="{{ product.name }}"
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    >
                    {# شارة الفئة #}
                    {% if product.category %}
                        <div class="absolute top-4 right-4 bg-gold text-dark-bg px-4 py-2 rounded-full text-sm font-bold">
                            {{ product.category }}
                        </div>
                    {% endif %}

                    {# زر المفضلة #}
                    <button class="absolute top-4 left-4 w-10 h-10 bg-dark-bg/80 hover:bg-gold/20 rounded-full flex items-center justify-center transition-all duration-300" id="wishlist-btn">
                        <i class="far fa-heart text-gold text-lg"></i>
                    </button>
                </div>

                {# صور مصغرة إضافية #}
                <div class="grid grid-cols-4 gap-4">
                    {# يمكن إضافة صور مصغرة هنا في حالة وجود معرض صور متعدد #}
                    {% if product.images %}
                        {% for image in product.images %}
                            <button class="relative rounded-lg overflow-hidden border-2 border-dark-border hover:border-gold transition-colors h-24">
                                <img src="{{ image.url }}" alt="صورة" class="w-full h-full object-cover">
                            </button>
                        {% endfor %}
                    {% else %}
                        <button class="relative rounded-lg overflow-hidden border-2 border-gold/50 h-24 flex items-center justify-center bg-dark-card">
                            <i class="fas fa-image text-gold/30 text-2xl"></i>
                        </button>
                    {% endif %}
                </div>
            </div>

            {# === معلومات المنتج Product Information === #}
            <div class="space-y-8">
                {# العنوان والتقييم #}
                <div>
                    <h1 class="text-4xl font-bold mb-4">{{ product.name }}</h1>
                    {# التقييمات #}
                    <div class="flex items-center gap-4 mb-6">
                        <div class="flex text-gold">
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star-half-alt"></i>
                        </div>
                        <span class="text-gray-400">(127 تقييم)</span>
                    </div>
                </div>

                {# السعر #}
                <div class="space-y-4 p-6 rounded-xl bg-dark-card border-2 border-gold/30">
                    <div class="flex items-baseline gap-4">
                        <span class="text-4xl font-bold text-gold">{{ product.price }}</span>
                        <span class="text-gray-500 line-through text-lg">{{ product.compare_price }}</span>
                        <span class="px-3 py-1 bg-red-500/20 text-red-400 rounded-full text-sm font-bold">خصم 25%</span>
                    </span>
                    </div>
                    <p class="text-sm text-gray-400">السعر يشمل جميع الضرائب والرسوم</p>
                </div>

                {# الوصف القصير #}
                <div class="space-y-3">
                    <h3 class="text-xl font-bold text-gold">نبذة عن المنتج</h3>
                    <p class="text-gray-300 leading-relaxed">
                        {{ product.description }}
                    </p>
                </div>

                {# قائمة مميزات المنتج #}
                <div class="space-y-3">
                    <h3 class="text-xl font-bold text-gold">مميزات المنتج</h3>
                    <ul class="space-y-2">
                        <li class="flex items-start gap-3">
                            <i class="fas fa-check text-gold mt-1 flex-shrink-0"></i>
                            <span class="text-gray-300">جودة عالية ومحتوى متكامل</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <i class="fas fa-check text-gold mt-1 flex-shrink-0"></i>
                            <span class="text-gray-300">وصول مدى الحياة بدون حد زمني</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <i class="fas fa-check text-gold mt-1 flex-shrink-0"></i>
                            <span class="text-gray-300">تحميل فوري بعد الدفع</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <i class="fas fa-check text-gold mt-1 flex-shrink-0"></i>
                            <span class="text-gray-300">دعم متخصص وتحديثات مستمرة</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <i class="fas fa-check text-gold mt-1 flex-shrink-0"></i>
                            <span class="text-gray-300">ضمان الرضا 30 يوم أو استرجاع أموالك</span>
                        </li>
                    </ul>
                </div>

                {# أزرار الإجراء #}
                <div class="space-y-3 pt-6 border-t border-dark-border">
                    {# زر إضافة إلى السلة #}
                    <button class="w-full py-4 bg-gradient-to-r from-gold to-gold-dark text-dark-bg font-bold text-lg rounded-lg hover:shadow-lg hover:shadow-gold/50 transition-all duration-300 flex items-center justify-center gap-2 group" id="add-to-cart-btn">
                        <i class="fas fa-shopping-bag group-hover:scale-110 transition-transform"></i>
                        أضف إلى السلة
                    </button>

                    {# زر الشراء الفوري #}
                    <button class="w-full py-4 border-2 border-gold/50 text-gold font-bold text-lg rounded-lg hover:border-gold hover:bg-gold/10 transition-all duration-300 flex items-center justify-center gap-2">
                        <i class="fas fa-bolt"></i>
                        شراء فوري
                    </button>

                    {# زر المشاركة #}
                    <button class="w-full py-3 border-2 border-dark-border text-gray-300 font-bold rounded-lg hover:border-gold/50 transition-all duration-300 flex items-center justify-center gap-2">
                        <i class="fas fa-share-alt"></i>
                        شارك هذا المنتج
                    </button>
                </div>

                {# معلومات إضافية #}
                <div class="grid grid-cols-3 gap-4 pt-6 border-t border-dark-border">
                    <div class="text-center">
                        <i class="fas fa-shield-alt text-gold text-2xl mb-2 block"></i>
                        <p class="text-sm text-gray-400">ضمان الرضا</p>
                    </div>
                    <div class="text-center">
                        <i class="fas fa-truck text-gold text-2xl mb-2 block"></i>
                        <p class="text-sm text-gray-400">تحميل فوري</p>
                    </div>
                    <div class="text-center">
                        <i class="fas fa-headset text-gold text-2xl mb-2 block"></i>
                        <p class="text-sm text-gray-400">دعم 24/7</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{# === قسم المنتجات ذات الصلة Related Products === #}
<section class="py-20 px-4 sm:px-6 lg:px-8 bg-dark-card/50 border-t border-dark-border">
    <div class="max-w-6xl mx-auto">
        <div class="mb-12">
            <h2 class="text-3xl font-bold mb-2">
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-gold-light to-gold">منتجات ذات صلة</span>
            </h2>
            <p class="text-gray-400">قد تعجبك هذه المنتجات أيضاً</p>
        </div>

        {# شبكة المنتجات ذات الصلة #}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            {% for relatedProduct in products limit(4) %}
                {% if relatedProduct.id != product.id %}
                    {% include 'components/product-card.twig' with {'product': relatedProduct} %}
                {% endif %}
            {% endfor %}
        </div>
    </div>
</section>

{# سكريبت يعالج زر إضافة إلى السلة #}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const addToCartBtn = document.getElementById('add-to-cart-btn');

    if (addToCartBtn) {
        addToCartBtn.addEventListener('click', function() {
            {# استدعاء Salla API لإضافة المنتج إلى السلة #}
            window.salla.event.dispatch('cart.add', {
                product_id: {{ product.id }},
                quantity: 1
            });
        });
    }

    {# زر المفضلة #}
    const wishlistBtn = document.getElementById('wishlist-btn');
    if (wishlistBtn) {
        wishlistBtn.addEventListener('click', function(e) {
            e.preventDefault();
            this.classList.toggle('active');
            const icon = this.querySelector('i');
            icon.classList.toggle('far');
            icon.classList.toggle('fas');
        });
    }
});
</script>

{% endblock %}
