{# صفحة مقالة واحدة - Single Blog Post Page #}
{% extends "layouts/master.twig" %}

{% block title %}{{ post.title }} - Velora{% endblock %}
{% block description %}{{ post.excerpt }}{% endblock %}

{% block content %}

{# === شريط البرتقالي Breadcrumb Navigation === #}
<div class="bg-dark-card/50 border-b border-gold/20 sticky top-24 z-40">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <nav class="flex items-center gap-2 text-sm">
            <a href="/" class="text-gold hover:text-gold-light transition-colors">
                {{ trans('breadcrumb.home') ?: 'الرئيسية' }}
            </a>
            <span class="text-gray-500"><i class="fas fa-chevron-left"></i></span>
            <a href="/blog" class="text-gold hover:text-gold-light transition-colors">{{ trans('breadcrumb.blog') ?: 'المدونة' }}</a>
            <span class="text-gray-500"><i class="fas fa-chevron-left"></i></span>
            <span class="text-gray-400">{{ post.title }}</span>
        </nav>
    </div>
</div>

{# === رأس المقالة Article Header === #}
<section class="relative py-16 px-4 sm:px-6 lg:px-8 overflow-hidden">
    <div class="max-w-4xl mx-auto">

        {# صورة المقالة #}
        {% if post.image %}
            <div class="relative rounded-3xl overflow-hidden mb-12 aspect-video">
                <img src="{{ post.image.url }}" alt="{{ post.title }}" class="w-full h-full object-cover">
                <div class="absolute inset-0 bg-gradient-to-t from-dark-bg/80 to-transparent"></div>
            </div>
        {% endif %}

        <div class="text-center mb-12">
            {# الفئة والتاريخ #}
            <div class="flex items-center justify-center gap-4 mb-6">
                <a href="{{ post.category.url }}" class="inline-block px-4 py-2 rounded-full bg-gold/20 border border-gold/50 text-gold text-sm font-semibold hover:bg-gold/30 transition-colors">
                    <i class="fas fa-tag ms-2"></i>{{ post.category.name }}
                </a>
                <span class="text-gray-400">{{ post.created_at|date('j F Y') }}</span>
            </div>

            {# العنوان الرئيسي #}
            <h1 class="text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
                {{ post.title }}
            </h1>

            {# معلومات المؤلف والقراءة #}
            <div class="flex items-center justify-center gap-8 mb-8 text-gray-400">
                <span class="flex items-center gap-2">
                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-gold to-gold-dark"></div>
                    {{ post.author.name }}
                </span>
                <span class="flex items-center gap-2">
                    <i class="fas fa-eye"></i>
                    {{ post.views }} {{ trans('blog.views') ?: 'عرض' }}
                </span>
                <span class="flex items-center gap-2">
                    <i class="fas fa-clock"></i>
                    {{ post.reading_time }} {{ trans('blog.reading_time') ?: 'دقيقة' }}
                </span>
            </div>

            {# أزرار المشاركة #}
            <div class="flex items-center justify-center gap-4">
                <button @click="sharePost('twitter')" class="p-3 bg-dark-card border border-gold/20 text-gold rounded-lg hover:bg-gold/10 transition-colors" title="{{ trans('blog.share_twitter') ?: 'شارك على تويتر' }}">
                    <i class="fab fa-twitter"></i>
                </button>
                <button @click="sharePost('facebook')" class="p-3 bg-dark-card border border-gold/20 text-gold rounded-lg hover:bg-gold/10 transition-colors" title="{{ trans('blog.share_facebook') ?: 'شارك على فيسبوك' }}">
                    <i class="fab fa-facebook"></i>
                </button>
                <button @click="sharePost('linkedin')" class="p-3 bg-dark-card border border-gold/20 text-gold rounded-lg hover:bg-gold/10 transition-colors" title="{{ trans('blog.share_linkedin') ?: 'شارك على لينكدإن' }}">
                    <i class="fab fa-linkedin"></i>
                </button>
                <button @click="copyPostLink" class="p-3 bg-dark-card border border-gold/20 text-gold rounded-lg hover:bg-gold/10 transition-colors" title="{{ trans('blog.copy_link') ?: 'انسخ الرابط' }}">
                    <i class="fas fa-link"></i>
                </button>
            </div>
        </div>
    </div>
</section>

{# === محتوى المقالة Post Content === #}
<section class="py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
        <article class="prose prose-invert max-w-none">
            <div class="text-gray-300 text-lg leading-relaxed space-y-6">
                {{ post.content }}
            </div>
        </article>

        {# الوسوم #}
        {% if post.tags %}
            <div class="mt-12 pt-8 border-t border-gold/20">
                <h3 class="text-lg font-bold text-white mb-4">{{ trans('blog.tags') ?: 'الوسوم' }}</h3>
                <div class="flex flex-wrap gap-3">
                    {% for tag in post.tags %}
                        <a href="/blog/tag/{{ tag.slug }}" class="px-4 py-2 rounded-full bg-dark-card border border-gold/30 text-gold text-sm font-semibold hover:bg-gold/10 transition-colors">
                            #{{ tag.name }}
                        </a>
                    {% endfor %}
                </div>
            </div>
        {% endif %}
    </div>
</section>

{# === معلومات المؤلف Author Info === #}
<section class="py-12 px-4 sm:px-6 lg:px-8 bg-dark-card/50 border-y border-gold/20">
    <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-8">
            <div class="w-24 h-24 rounded-2xl bg-gradient-to-br from-gold to-gold-dark flex-shrink-0"></div>

            <div>
                <h3 class="text-2xl font-bold text-white mb-2">{{ post.author.name }}</h3>
                <p class="text-gold font-semibold mb-3">{{ post.author.title }}</p>
                <p class="text-gray-400 leading-relaxed max-w-2xl">{{ post.author.bio }}</p>

                <div class="flex gap-4 mt-4">
                    {% if post.author.twitter %}
                        <a href="{{ post.author.twitter }}" class="text-gold hover:text-gold-light transition-colors">
                            <i class="fab fa-twitter text-lg"></i>
                        </a>
                    {% endif %}
                    {% if post.author.linkedin %}
                        <a href="{{ post.author.linkedin }}" class="text-gold hover:text-gold-light transition-colors">
                            <i class="fab fa-linkedin text-lg"></i>
                        </a>
                    {% endif %}
                    {% if post.author.website %}
                        <a href="{{ post.author.website }}" class="text-gold hover:text-gold-light transition-colors">
                            <i class="fas fa-globe text-lg"></i>
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>

{# === مقالات ذات صلة Related Posts === #}
{% if related_posts %}
    <section class="py-16 px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
            <h2 class="text-3xl font-bold text-white mb-8">{{ trans('blog.related_posts') ?: 'مقالات ذات صلة' }}</h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                {% for related_post in related_posts|slice(0, 2) %}
                    <a href="{{ related_post.url }}" class="group bg-dark-card rounded-2xl overflow-hidden border border-gold/20 hover:border-gold/50 transition-all duration-300">

                        <div class="h-48 overflow-hidden">
                            <img src="{{ related_post.image.url }}" alt="{{ related_post.title }}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                        </div>

                        <div class="p-6">
                            <p class="text-gold text-sm font-semibold mb-2">{{ related_post.category.name }}</p>
                            <h3 class="text-lg font-bold text-white mb-2 line-clamp-2 group-hover:text-gold transition-colors">
                                {{ related_post.title }}
                            </h3>
                            <p class="text-gray-400 text-sm line-clamp-2 mb-4">{{ related_post.excerpt }}</p>
                            <span class="text-gold text-sm font-semibold group-hover:translate-x-2 inline-block transition-transform">
                                {{ trans('blog.read_more') ?: 'اقرأ المزيد' }} →
                            </span>
                        </div>
                    </a>
                {% endfor %}
            </div>
        </div>
    </section>
{% endif %}

{# === التعليقات Comments Section === #}
<section class="py-16 px-4 sm:px-6 lg:px-8 bg-dark-card/50 border-t border-gold/20">
    <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-white mb-8">{{ trans('blog.comments') ?: 'التعليقات' }}</h2>

        {# نموذج التعليق #}
        <div class="bg-dark-bg rounded-2xl p-8 mb-12 border border-gold/20">
            <h3 class="text-xl font-bold text-white mb-6">{{ trans('blog.leave_comment') ?: 'اترك تعليقاً' }}</h3>

            <form @submit.prevent="submitComment" class="space-y-4">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <input type="text" v-model="comment.name" placeholder="{{ trans('blog.comment_name') ?: 'اسمك' }}" required class="bg-dark-card border border-gold/30 rounded-lg text-white placeholder-gray-500 px-4 py-3 focus:border-gold transition-colors">
                    <input type="email" v-model="comment.email" placeholder="{{ trans('blog.comment_email') ?: 'بريدك الإلكتروني' }}" required class="bg-dark-card border border-gold/30 rounded-lg text-white placeholder-gray-500 px-4 py-3 focus:border-gold transition-colors">
                </div>

                <textarea v-model="comment.content" placeholder="{{ trans('blog.comment_message') ?: 'اكتب تعليقك هنا...' }}" rows="6" required class="w-full bg-dark-card border border-gold/30 rounded-lg text-white placeholder-gray-500 px-4 py-3 focus:border-gold transition-colors resize-none"></textarea>

                <button type="submit" class="px-8 py-3 bg-gradient-to-r from-gold to-gold-dark text-dark-bg font-bold rounded-lg hover:shadow-lg hover:shadow-gold/50 transition-all duration-300">
                    {{ trans('blog.post_comment') ?: 'نشر التعليق' }}
                </button>
            </form>
        </div>

        {# عرض التعليقات #}
        {% if post.comments %}
            <div class="space-y-6">
                {% for comment in post.comments %}
                    <div class="bg-dark-bg rounded-2xl p-6 border border-gold/20">
                        <div class="flex items-start gap-4 mb-4">
                            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-gold to-gold-dark flex-shrink-0"></div>
                            <div>
                                <h4 class="font-bold text-white">{{ comment.author.name }}</h4>
                                <p class="text-gray-500 text-sm">{{ comment.created_at|date('j M Y - H:i') }}</p>
                            </div>
                        </div>
                        <p class="text-gray-300 leading-relaxed">{{ comment.content }}</p>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p class="text-center text-gray-400">{{ trans('blog.no_comments') ?: 'لا توجد تعليقات حتى الآن' }}</p>
        {% endif %}
    </div>
</section>

{% endblock %}
